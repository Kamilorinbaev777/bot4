<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>509e9b8b-efdd-4fc8-b8f0-e468e8f2ca65</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>main.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>ThePythonBot</Name>
    <RootNamespace>ThePythonBot</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="handlers\admins.py" />
    <Compile Include="handlers\developer.py" />
    <Compile Include="handlers\help.py" />
    <Compile Include="handlers\register.py" />
    <Compile Include="handlers\start.py" />
    <Compile Include="handlers\users.py" />
    <Compile Include="keyboards\developer.py" />
    <Compile Include="keyboards\start.py" />
    <Compile Include="main.py" />
    <Compile Include="middlewares\user.py" />
    <Compile Include="states\register.py" />
    <Compile Include="states\users.py" />
    <Compile Include="storage.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="middlewares\" />
    <Folder Include="keyboards\" />
    <Folder Include="handlers\" />
    <Folder Include="states\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include=".env" />
    <Content Include=".gitignore" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>